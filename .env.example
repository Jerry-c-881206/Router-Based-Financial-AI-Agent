# 複製此檔為 `.env` 並填入實際金鑰（勿將 `.env` 提交至版本庫）
# Copy to `.env` and fill in values. Never commit `.env`.

# OpenAI（LangChain ChatOpenAI）
OPENAI_API_KEY=

# Tavily（langchain_community TavilySearchResults）
TAVILY_API_KEY=

# FinMind（選用；程式會讀 FINMIND_API_TOKEN，若無則讀 FINMIND_TOKEN）
FINMIND_API_TOKEN=
